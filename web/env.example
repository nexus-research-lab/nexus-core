# 开发环境
# VITE_WS_URL=ws://localhost:8010/agent/v1/chat/ws
# VITE_API_URL=http://localhost:8010/agent/v1
# VITE_DEFAULT_MODEL=glm-5

# Docker / Nginx 同源代理生产环境（推荐留空，自动跟随当前域名）
VITE_WS_URL=
VITE_API_URL=
VITE_DEFAULT_MODEL=glm-5

# 如果使用域名，请替换为实际域名
# VITE_WS_URL=ws://yourdomain.com/agent/v1/chat/ws
# VITE_API_URL=https://yourdomain.com/agent/v1
