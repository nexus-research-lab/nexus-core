# Agent 运行时 Provider 以 Settings 页面中的 Provider 表为准。
# 不再通过环境变量配置 Provider 的 auth_token / base_url / model。


# App Configuration
HOST=0.0.0.0
PORT=8010
DEBUG=true
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_STDOUT=true
LOG_FILE_ENABLED=true
LOG_PATH=~/.nexus/logs/logger.log
LOG_ROTATE_DAILY=true
LOG_MAX_SIZE_MB=10
LOG_MAX_AGE_DAYS=7
LOG_MAX_BACKUPS=7
LOG_COMPRESS=true
DATABASE_DRIVER=sqlite
DATABASE_URL=~/.nexus/data/nexus.db
WORKSPACE_PATH=

# Browser Login / Public Deployment
# 首次启动后请执行：
# go run ./cmd/nexusctl auth init-owner --username admin --password <your-password>
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_COOKIE_NAME=nexus_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ACCESS_TOKEN=

# Channel Configuration
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=

# Connector OAuth Configuration
# 必须与各 provider 开发者后台登记的回调 URI 完全一致。
CONNECTOR_OAUTH_REDIRECT_URI=http://localhost:3000/capability/connectors/oauth/callback
# 允许 OAuth redirect_uri 的 scheme+host+path 前缀，多个值用逗号分隔。
CONNECTOR_OAUTH_ALLOWED_ORIGINS=http://localhost:3000
# OAuth state 有效期，单位秒。
CONNECTOR_OAUTH_STATE_TTL_SECONDS=600
# 32 字节 base64 密钥，用于加密 connector_connections.credentials_encrypted。
CONNECTOR_CREDENTIALS_KEY=
CONNECTOR_GITHUB_CLIENT_ID=
CONNECTOR_GITHUB_CLIENT_SECRET=
CONNECTOR_GOOGLE_CLIENT_ID=
CONNECTOR_GOOGLE_CLIENT_SECRET=
CONNECTOR_LINKEDIN_CLIENT_ID=
CONNECTOR_LINKEDIN_CLIENT_SECRET=
CONNECTOR_TWITTER_CLIENT_ID=
CONNECTOR_TWITTER_CLIENT_SECRET=
CONNECTOR_INSTAGRAM_CLIENT_ID=
CONNECTOR_INSTAGRAM_CLIENT_SECRET=
CONNECTOR_SHOPIFY_CLIENT_ID=
CONNECTOR_SHOPIFY_CLIENT_SECRET=
